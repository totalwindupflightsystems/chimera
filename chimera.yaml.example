# Chimera Configuration
# Copy to chimera.yaml and fill in your API keys.

# --------------------------------------------------------------------------- #
# API Authentication (F1)
# --------------------------------------------------------------------------- #
auth:
  # Set enabled: true to require API keys on protected endpoints
  enabled: false
  # mode: "env" — single key from CHIMERA_API_KEY environment variable
  # mode: "list" — multiple named keys from the keys list below
  mode: env
  keys: []
  #   - key: "your-api-key-here"
  #     name: "admin"

# --------------------------------------------------------------------------- #
# Rate Limiting (F2)
# --------------------------------------------------------------------------- #
rate_limit:
  enabled: false
  requests_per_minute: 60
  burst_size: 10

# --------------------------------------------------------------------------- #
# Circuit Breakers (F3)
# --------------------------------------------------------------------------- #
circuit_breakers:
  # Default configuration applied to all providers unless overridden
  default:
    failure_threshold: 5       # consecutive failures before opening
    recovery_timeout_s: 30     # seconds to wait before testing recovery
    half_open_max_requests: 1  # test requests allowed in half-open state

# --------------------------------------------------------------------------- #
# Retry / Backoff (F7)
# --------------------------------------------------------------------------- #
retry:
  max_attempts: 3
  base_delay_ms: 500
  max_delay_ms: 10000
  backoff_multiplier: 2.0

# --------------------------------------------------------------------------- #
# Request Queue / Backpressure (F5)
# --------------------------------------------------------------------------- #
queue:
  max_concurrent: 10
  max_queue_depth: 100

api_keys:
  deepseek: ${DEEPSEEK_API_KEY}
  openrouter: ${OPENROUTER_API_KEY}
  zai: ${ZAI_API_KEY}

# Budget-first defaults — cheap models for dispatch/aggregation.
# Every request can override ANY of these via API params.
defaults:
  dispatcher: deepseek/deepseek-v4-pro           # Budget dispatcher (V4 class)
  default_worker: deepseek/deepseek-v4-pro        # Budget worker
  default_aggregator: deepseek/deepseek-v4-pro         # Budget aggregator
  # Lock a role's model so the dispatcher CANNOT override it (uses the default above):
  lock_dispatcher: false   # force `dispatcher` model for any dispatcher-kind stage
  lock_aggregator: false   # force `default_aggregator` for aggregator/merge/audit stages
  # Premium alternatives available as overrides:
  #   zai-coding-plan/glm-5.2, openrouter/anthropic/claude-sonnet-4

formations:
  auto:
    mode: auto
  simple:
    workers: 2
    aggregator: default
  debate:
    workers: 3
    aggregators:
      - default
      - openrouter/anthropic/claude-sonnet-4
    merge: best_of_n
  audit:
    workers: 2
    aggregator: default
    audit: openrouter/anthropic/claude-haiku-4.5
  # Config-defined custom formation — arbitrary DAG (Feature 3).
  # `dag` wins over `workers`/`aggregator`. The dispatcher still writes a
  # custom prompt per worker and merge instructions per aggregator (FILL-IN).
  # Any preset (including simple/debate/audit above) may be redefined this way.
  my-custom-chain:
    dag:
      stages:
        - id: analyzer
          kind: worker
          model: deepseek/deepseek-v4-pro
        - id: reviewer
          kind: aggregator
          model: zai-coding-plan/glm-5.2
          depends_on: [analyzer]
        - id: implementer
          kind: worker
          model: openrouter/anthropic/claude-sonnet-4
          depends_on: [reviewer]
        - id: verifier
          kind: aggregator
          model: zai-coding-plan/glm-5.2
          depends_on: [implementer]
        - id: finalizer
          kind: merge
          model: deepseek/deepseek-v4-pro
          depends_on: [verifier]
      edges:
        - [analyzer, reviewer]
        - [reviewer, implementer]
        - [implementer, verifier]
        - [verifier, finalizer]

models:
  deepseek/deepseek-v4-pro:
    categories:
      analysis: 0.85
      audit: 0.6
      code: 0.95
      design: 0.4
      reasoning: 0.8
    cost_tier: budget
    provider: deepseek                               # Direct API (set DEEPSEEK_API_KEY)

  openrouter/anthropic/claude-sonnet-4:
    categories:
      analysis: 0.92
      audit: 0.85
      code: 0.9
      design: 0.88
      reasoning: 0.93
    cost_tier: premium
    provider: openrouter                             # Via OpenRouter (set OPENROUTER_API_KEY)

  openrouter/google/gemini-2.5-flash:
    categories:
      analysis: 0.75
      audit: 0.5
      code: 0.7
      design: 0.9
      reasoning: 0.65
    cost_tier: budget
    provider: openrouter

  zai-coding-plan/glm-5.2:
    categories:
      analysis: 0.9
      audit: 0.88
      code: 0.92
      design: 0.85
      reasoning: 0.95
    cost_tier: premium
    provider: zai

providers:
  anthropic:
    base_url: https://api.anthropic.com/v1
  openrouter:
    base_url: https://openrouter.ai/api/v1
  zai:
    base_url: https://api.z.ai/api/coding/paas/v4

server:
  host: 0.0.0.0
  port: 8000

# ------------------------------------------------------------------ #
# Resilience configuration (F5–F8)
# ------------------------------------------------------------------ #

# F7: Retry with exponential backoff for transient provider failures
retry:
  max_attempts: 3          # Total attempts (including the first)
  base_delay_ms: 500       # Initial delay in milliseconds
  max_delay_ms: 10000      # Maximum delay cap (10 seconds)
  backoff_multiplier: 2.0  # Multiply delay each attempt

# F5: Request queue / backpressure
queue:
  max_concurrent: 10       # Maximum simultaneously executing requests
  max_queue_depth: 100     # Maximum waiting requests (503 when full)

observability:
  log_level: info
  trace_enabled: true
  use_stdout: true          # emit structlog JSON to stdout (default) instead of stderr
  langfuse:
    enabled: false
