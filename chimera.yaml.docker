api_keys:
  deepseek: ${DEEPSEEK_API_KEY}
  openrouter: ${OPENROUTER_API_KEY}
  zai: ${ZAI_API_KEY}
  anthropic: ${ANTHROPIC_API_KEY}
  google: ${GEMINI_API_KEY}

defaults:
  dispatcher: deepseek/deepseek-v4-flash
  default_worker: deepseek/deepseek-v4-pro
  default_aggregator: deepseek/deepseek-v4-flash
  lock_dispatcher: false
  lock_aggregator: true

formations:
  audit:
    audit: default
    aggregator: default
    workers: 2
  auto:
    mode: auto
  debate:
    aggregators:
    - default
    - default
    merge: best_of_n
    workers: 2
  simple:
    aggregator: default
    workers: 2

# ── Model Catalog (27 models, 9 providers) ──────────────────────────────────
# Category weights: code | analysis | reasoning | design | audit  (0.0-1.0)
# Cost tiers: budget (<$1/Mtok) | standard ($1-10) | premium (>$10)
# Updated 2026-06-20 — research-backed from SWE-bench, AIME, GPQA, LiveCodeBench

